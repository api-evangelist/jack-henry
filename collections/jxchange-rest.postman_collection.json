  "info": {
    "_postman_id": "42ff46ab-0302-42dd-8b55-5b2faffb8491",
    "name": "jXchange REST",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json",
    "description": {
      "content": "jXchange is Jack Henry's information-translation surface that brokers\nrequests between third-party applications and the SilverLake or\nCIF 20/20 community-bank cores. The REST variant exposes deposits,\nloans, customers, accounts, transactions, and general-ledger domains.\nA SOAP variant is also published at jackhenry.dev/jxchange-soap/.\n",
      "type": "text/plain"
    }
  }
