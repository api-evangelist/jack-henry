    "_postman_id": "74a2707d-3149-4333-8620-5e0f214d7552",
    "name": "Banno Authentication Framework",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json",
    "description": {
      "content": "OAuth 2.0 and OpenID Connect surface that issues access tokens,\nidentity tokens, and refresh tokens for the Banno Consumer API,\nAdmin API, and Plugin Framework. Implements the permissions flow\nused to enforce scopes on protected endpoints. Per the documentation:\n\"Protect user data using industry standard OAuth 2.0 and OpenID\nConnect to provide authenticated information in the form of secure\naccess and identity tokens.\"\n",
      "type": "text/plain"
    }
  }
