          },
          "docs": "Get OpenID Connect Discovery Document"
        },
        {
          "info": {
            "name": "Get JWKS",
            "type": "http"
          },
          "http": {
            "method": "GET",
            "url": "https://api.banno.com/a/oidc/.well-known/jwks.json"
          },
          "docs": "Get JWKS"
        }
      ]
    },
    {
