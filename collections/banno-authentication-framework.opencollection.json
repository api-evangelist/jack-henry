              },
              {
                "name": "redirect_uri",
                "value": "",
                "type": "query"
              },
              {
                "name": "scope",
                "value": "",
                "type": "query"
              },
              {
                "name": "state",
                "value": "",
                "type": "query"
              },
              {
                "name": "code_challenge",
                "value": "",
                "type": "query"
              },
              {
                "name": "code_challenge_method",
                "value": "",
                "type": "query"
              }
            ]
          },
          "docs": "Authorize OAuth Request"
        }
      ]
    },
    {
      "info": {
        "name": "Token",
        "type": "folder"
      },
      "items": [
        {
          "info": {
            "name": "Exchange Token",
            "type": "http"
          },
          "http": {
            "method": "POST",
            "url": "https://api.banno.com/a/oidc/token",
            "body": {
              "type": "form-urlencoded",
              "data": [
                {
                  "name": "grant_type",
                  "value": ""
