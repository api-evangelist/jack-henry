                {
                  "name": "code",
                  "value": ""
                },
                {
                  "name": "redirect_uri",
                  "value": ""
                },
                {
                  "name": "client_id",
                  "value": ""
                },
                {
                  "name": "client_secret",
                  "value": ""
                },
                {
                  "name": "code_verifier",
                  "value": ""
                },
                {
                  "name": "refresh_token",
                  "value": ""
                },
                {
                  "name": "scope",
                  "value": ""
                }
              ]
            }
          },
          "docs": "Exchange Token"
        }
      ]
    },
    {
      "info": {
        "name": "UserInfo",
        "type": "folder"
      },
      "items": [
        {
          "info": {
            "name": "Get UserInfo",
            "type": "http"
          },
          "http": {
            "method": "GET",
            "url": "https://api.banno.com/a/oidc/userinfo",
            "auth": {
              "type": "bearer",
              "token": "{{bearerToken}}"
            }
          },
          "docs": "Get UserInfo"
        }
      ]
    }
  ],
  "bundled": true
}